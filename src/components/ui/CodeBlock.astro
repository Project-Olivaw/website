---
import { Code } from 'astro:components';
import type { CodeBlockProps } from '../../types/components';
import Icon from './Icon.astro';

interface Props extends CodeBlockProps {}

const { code, language, filename } = Astro.props;
---

<div class="code-block" role="region" aria-label="Code example">
  {
    filename && (
      <div class="code-block__header">
        <span class="code-block__filename">{filename}</span>
        <div class="code-block__dots" aria-hidden="true">
          <span></span>
          <span></span>
          <span></span>
        </div>
      </div>
    )
  }
  <div class="code-block__body">
    <Code
      code={code}
      lang={language as Parameters<typeof Code>[0]['lang']}
      themes={{ light: 'github-light', dark: 'github-dark' }}
    />
    <button
      class="code-block__copy"
      data-code={code}
      aria-label="Copy code to clipboard"
      title="Copy code"
    >
      <span class="copy-icon">
        <Icon name="copy" size={14} ariaHidden={true} />
      </span>
      <span class="check-icon">
        <Icon name="check" size={14} ariaHidden={true} />
      </span>
    </button>
  </div>
</div>

<script>
  document.querySelectorAll<HTMLButtonElement>('.code-block__copy').forEach((btn) => {
    btn.addEventListener('click', async () => {
      const code = btn.dataset.code ?? '';
      try {
        await navigator.clipboard.writeText(code);
        btn.classList.add('copied');
        setTimeout(() => btn.classList.remove('copied'), 2000);
      } catch (_) {}
    });
  });
</script>

<style>
  .code-block {
    border-radius: var(--radius-lg);
    border: 1px solid var(--color-border);
    overflow: hidden;
    font-family: var(--font-mono);
    font-size: var(--text-sm);
  }

  .code-block__header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0.625rem 1rem;
    background-color: var(--color-bg-subtle);
    border-bottom: 1px solid var(--color-border);
  }

  .code-block__filename {
    font-size: var(--text-xs);
    font-family: var(--font-mono);
    color: var(--color-text-muted);
  }

  .code-block__dots {
    display: flex;
    gap: 0.375rem;
  }

  .code-block__dots span {
    display: block;
    width: 10px;
    height: 10px;
    border-radius: 50%;
    background-color: var(--color-border);
  }

  .code-block__body {
    position: relative;
  }

  .code-block__body pre {
    padding: 1.25rem 1rem !important;
    margin: 0 !important;
    overflow-x: auto;
    font-size: var(--text-sm) !important;
    line-height: 1.7 !important;
    border-radius: 0 !important;
  }

  .code-block__copy {
    position: absolute;
    top: 0.625rem;
    right: 0.625rem;
    display: flex;
    align-items: center;
    justify-content: center;
    width: 2rem;
    height: 2rem;
    border-radius: var(--radius-md);
    border: 1px solid var(--color-border);
    background-color: var(--color-surface);
    color: var(--color-text-muted);
    cursor: pointer;
    opacity: 0;
    transition:
      opacity var(--transition-fast),
      color var(--transition-fast),
      background-color var(--transition-fast);
  }

  .code-block:hover .code-block__copy {
    opacity: 1;
  }

  .code-block__copy:hover {
    color: var(--color-text-primary);
    background-color: var(--color-bg-subtle);
  }

  .check-icon {
    display: none;
    color: #22c55e;
  }

  .code-block__copy.copied .copy-icon {
    display: none;
  }

  .code-block__copy.copied .check-icon {
    display: flex;
  }
</style>
