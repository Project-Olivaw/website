---
import type { CardProps } from '../../types/components';
import Badge from './Badge.astro';
import Icon from './Icon.astro';

interface Props extends CardProps {}

const {
  title,
  description,
  tags = [],
  href,
  badgeText,
  badgeColor = 'gray',
  iconName,
  accentColor,
} = Astro.props;

const accentClass = accentColor ? `accent-border-${accentColor}` : '';
---

<div class={`card ${accentClass}`}>
  <div class="card__header">
    {
      iconName && (
        <div class={`card__icon card__icon--${accentColor ?? 'gray'}`}>
          <Icon name={iconName} size={20} ariaHidden={true} />
        </div>
      )
    }
    {badgeText && <Badge text={badgeText} color={badgeColor} />}
  </div>

  <h3 class="card__title">
    {
      href ? (
        <a href={href} class="card__link">
          {title}
        </a>
      ) : (
        title
      )
    }
  </h3>

  <p class="card__description">{description}</p>

  {
    tags.length > 0 && (
      <div class="card__tags">
        {tags.map((tag) => (
          <span class="card__tag">{tag}</span>
        ))}
      </div>
    )
  }
</div>

<style>
  .card {
    background-color: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    padding: 1.75rem;
    display: flex;
    flex-direction: column;
    gap: 0.875rem;
    transition:
      border-color var(--transition-fast),
      box-shadow var(--transition-fast),
      transform var(--transition-base);
  }

  .card:hover {
    border-color: var(--color-text-muted);
    box-shadow: 0 4px 24px color-mix(in srgb, var(--color-text-primary) 6%, transparent);
    transform: translateY(-2px);
  }

  .card__header {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 0.75rem;
  }

  .card__icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 2.5rem;
    height: 2.5rem;
    border-radius: var(--radius-md);
    flex-shrink: 0;
  }

  .card__icon--blue {
    color: var(--color-accent-blue);
    background-color: color-mix(in srgb, var(--color-accent-blue) 12%, transparent);
  }

  .card__icon--red {
    color: var(--color-accent-red);
    background-color: color-mix(in srgb, var(--color-accent-red) 12%, transparent);
  }

  .card__icon--yellow {
    color: color-mix(in srgb, var(--color-accent-yellow) 70%, var(--color-text-primary) 30%);
    background-color: color-mix(in srgb, var(--color-accent-yellow) 15%, transparent);
  }

  .card__icon--gray {
    color: var(--color-text-muted);
    background-color: var(--color-bg-subtle);
  }

  .card__title {
    font-size: var(--text-xl);
    font-weight: 700;
    letter-spacing: -0.01em;
    color: var(--color-text-primary);
    line-height: 1.3;
  }

  .card__link {
    text-decoration: none;
    color: inherit;
    transition: color var(--transition-fast);
  }

  .card__link:hover {
    color: var(--color-accent-blue);
  }

  .card__description {
    font-size: var(--text-sm);
    color: var(--color-text-secondary);
    line-height: 1.7;
  }

  .card__tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.375rem;
    margin-top: auto;
    padding-top: 0.25rem;
  }

  .card__tag {
    font-size: var(--text-xs);
    font-family: var(--font-mono);
    color: var(--color-text-muted);
    background-color: var(--color-bg-subtle);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-sm);
    padding: 0.2rem 0.5rem;
  }
</style>
